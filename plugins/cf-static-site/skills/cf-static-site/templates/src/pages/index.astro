---
import Base from "../layouts/Base.astro";
---

<Base title="<DOMAIN>">
	<section
		class="flex-1 w-full max-w-[var(--container-max)] mx-auto px-6 py-20 md:py-28 flex flex-col items-center text-center gap-8"
	>
		<h1 class="font-display text-3xl md:text-5xl font-bold tracking-tight">
			<DOMAIN>
		</h1>

		<a href="#" class="inline-block">
			<img src="/github.svg" alt="Get it on GitHub" width="135" height="40" />
		</a>

		<p class="text-sm text-[var(--color-on-surface-muted)]">
			Coming Soon
		</p>
	</section>
</Base>
